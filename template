# Template file for 'brave-bin'
pkgname=brave-bin
version=1.91.168
revision=1
only_for_archs="x86_64"
short_desc="Secure, fast and private web browser with ad blocker"
maintainer="Soanvig <soanvig@gmail.com>"
hostmakedepends="tar xz"
depends="alsa-lib nss gtk+3"
noverifyrdeps=yes
license="Mozilla Public License Version 2.0"
homepage="https://brave.com"
distfiles="https://github.com/brave/brave-browser/releases/download/v/brave-browser__amd64.deb"
checksum=e715b41e10ccf5c821ee1d2143e074371687c3b0ce6cb497ce0c22c68fa336d7
nostrip=yes

do_extract() {
    mkdir -p 
    ar x /-/brave-browser__amd64.deb
}

do_install() {
    tar xf data.tar.xz -C 

    # Install the icons
    for size in 24 32 48 64 128 256; do
        # Create the brave browser xdg directory
        mkdir -p /usr/share/icons/hicolor/x/apps

        # Copy the brave browser icon
        mv /opt/brave.com/brave/product_logo_.png         /usr/share/icons/hicolor/x/apps/brave-browser.png
    done

    # Remove the Debian/Ubuntu crontab
    rm -rf /etc
    rm -rf /opt/brave.com/brave/cron
}
